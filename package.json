    "express": "^5.2.1",
    "mongodb": "^7.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
